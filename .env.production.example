# 生产环境变量配置
# 复制为 .env.local 或在 Railway/Render 后台设置

# ------------ 应用基础配置 ------------
APP_NAME=movie-recommender-backend
ENVIRONMENT=prod
DEBUG=false

# ------------ 数据库配置 (Supabase PostgreSQL) ------------
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ------------ AI / LLM 配置 ------------
# 智谱 AI（用于 Embedding 和 LLM）
ZHIPUAI_API_KEY=your_zhipuai_api_key

# ------------ 向量数据库配置 (Qdrant Cloud) ------------
QDRANT_URL=https://your-project.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# ------------ 第三方 API 配置 ------------
# TMDB API（电影数据源）
TMDB_API_KEY=your_tmdb_api_key

# ------------ JWT 配置 (重要！生产环境请修改) ------------
JWT_SECRET_KEY=generate-a-secure-random-string-here-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------ 前端配置 ------------
# 前端域名（用于 CORS）
NEXT_PUBLIC_API_URL=https://your-frontend.vercel.app