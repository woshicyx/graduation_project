# ============ 智能电影推荐平台 - 环境变量 ============
# 复制此文件为 .env.local 在各子项目中使用，或按需在根目录统一管理后由各应用加载。
# 请勿将真实密钥提交到版本控制。

# ------------ AI / LLM (OpenAI 或兼容接口) ------------
OPENAI_API_KEY=sk-556ab99a657a472ba883eb60944692e5
# 可选：兼容 OpenAI 的接口 base URL（如本地模型、Azure 等）
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# ------------ 关系型数据库 (PostgreSQL) ------------
DATABASE_URL=postgresql://postgres:356921@localhost:5432/movie_recommendation

# ------------ 向量库 -----------
# Qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Pinecone（若使用 Pinecone 则注释上方 Qdrant，并填写下方）
# PINECONE_API_KEY=
# PINECONE_INDEX=
# PINECONE_ENVIRONMENT=

# ------------ 数据源 (TMDB API) ------------
TMDB_API_KEY=
# 可选：TMDB 接口 base（默认 https://api.themoviedb.org/3）
# TMDB_API_BASE=https://api.themoviedb.org/3

# ------------ 前端 / Next.js ------------
# 后端 API 地址（Next.js API Routes 或 FastAPI 服务）
NEXT_PUBLIC_API_URL=http://localhost:3000/api
