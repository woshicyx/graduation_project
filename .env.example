# ==================== 智能电影推荐平台 - 统一环境变量配置 ====================
# 将此文件复制为 .env.local 或 .env 使用
# 请勿将真实密钥提交到版本控制

# ------------ 应用基础配置 ------------
APP_NAME=movie-recommender-backend
ENVIRONMENT=dev
DEBUG=true

# ------------ 数据库配置 ------------
DATABASE_URL=postgresql://user:password@localhost:5432/movie_recommendation

# ------------ AI / LLM 配置 ------------
# OpenAI 或兼容接口
OPENAI_API_KEY=your_openai_api_key_here
# 可选：兼容 OpenAI 的接口 base URL（如本地模型、Azure 等）
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# ------------ 向量数据库配置 ------------
# 选项 1: Qdrant（推荐）
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# 选项 2: Pinecone（若使用 Pinecone 则注释上方 Qdrant）
# PINECONE_API_KEY=
# PINECONE_INDEX=
# PINECONE_ENVIRONMENT=

# ------------ 第三方 API 配置 ------------
# TMDB API（电影数据源）
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_API_BASE=https://api.themoviedb.org/3

# ------------ JWT 配置 ------------
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24小时

# ------------ 前端配置 ------------
# 后端 API 地址（前端通过此地址访问后端）
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ------------ 后端服务器配置 ------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true